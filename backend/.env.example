APP_ENV=production
APP_VERSION=1.1.0

DATABASE_URL=postgresql://usuario:senha@host:5432/novaris
SECRET_KEY=gere-uma-chave-aleatoria-com-pelo-menos-32-caracteres
PAYMENT_ENCRYPTION_KEY=gere-outra-chave-aleatoria-com-pelo-menos-32-caracteres

JWT_EXPIRE_MINUTES=30
JWT_REFRESH_DAYS=30
FRONTEND_URL=https://app.novarisagro.com.br
PUBLIC_API_URL=https://api.novarisagro.com.br
COOKIE_DOMAIN=.novarisagro.com.br

ALLOWED_ORIGINS=https://app.novarisagro.com.br,https://novarisagro.com.br
ALLOWED_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?novarisagro\.com\.br$
ALLOWED_HOSTS=api.novarisagro.com.br,*.onrender.com

ENABLE_DOCS=false
LOG_LEVEL=INFO
RUN_MIGRATIONS_ON_STARTUP=false
RUN_DATABASE_SETUP_ON_STARTUP=true
WEB_CONCURRENCY=1
GUNICORN_TIMEOUT=60
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
