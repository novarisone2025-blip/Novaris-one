# Ambiente
APP_ENV=development
APP_VERSION=1.1.0
FRONTEND_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:8000

# Banco
POSTGRES_DB=novaris
POSTGRES_USER=novaris
POSTGRES_PASSWORD=defina-uma-senha-forte
DATABASE_URL=postgresql+psycopg://novaris:defina-uma-senha-forte@banco:5432/novaris

# Seguranca
SECRET_KEY=gere-uma-chave-aleatoria-com-pelo-menos-32-caracteres
PAYMENT_ENCRYPTION_KEY=gere-outra-chave-aleatoria-com-32-caracteres
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_DAYS=30
COOKIE_DOMAIN=

# CORS e hosts
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?novarisagro\.com\.br$
ALLOWED_HOSTS=*

# Execucao
LOG_LEVEL=INFO
ENABLE_DOCS=true
RUN_MIGRATIONS_ON_STARTUP=true
RUN_DATABASE_SETUP_ON_STARTUP=true
WEB_CONCURRENCY=1
BACKEND_PORT=8000

# Frontend
VITE_API_URL=http://localhost:8000

# Migracao unica do banco SQLite existente
SQLITE_SOURCE_URL=sqlite:///./novaris_one_etapa1.db
